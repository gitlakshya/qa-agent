# =============================================================================
# QA Agent - Production Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration (Required)
# -----------------------------------------------------------------------------
AZURE_INFERENCE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_INFERENCE_CREDENTIAL=your-api-key-here
AZURE_DEPLOYMENT_NAME=your-deployment-name
AZURE_MODEL_NAME=gpt-4
AZURE_API_VERSION=2024-10-01-preview

# -----------------------------------------------------------------------------
# TestRail Integration Configuration (Required for sync features)
# -----------------------------------------------------------------------------
TESTRAIL_URL=https://your-instance.testrail.io
TESTRAIL_USERNAME=your-email@company.com
TESTRAIL_API_KEY=your-testrail-api-key

# TestRail API Settings (Optional - defaults shown)
TESTRAIL_TIMEOUT=30
TESTRAIL_MAX_RETRIES=3
TESTRAIL_RETRY_DELAY=1.0
TESTRAIL_RATE_LIMIT=180
TESTRAIL_REQUEST_DELAY=0.4

# -----------------------------------------------------------------------------
# Optional: Local LLM Configuration (Ollama)
# -----------------------------------------------------------------------------
# Uncomment if using Ollama instead of Azure OpenAI
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:latest

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Document directories
PDF_DIR=Related_docs
EXTRA_DIRS=MR-releaseNotes,Jira_CSV

# Output directory for generated test cases
OUTPUT_DIR=./test_cases_output

# Vector database (not used in current production version)
# DB_DIR=chroma-db